# =============================================================================
# AI Report Video Analyzer — Configurazione
# =============================================================================
# 1. Copia questo file: cp .env.example .env
# 2. Compila i campi obbligatori e quelli del backend che vuoi usare
# 3. NON committare mai il file .env (è già in .gitignore)
# =============================================================================


# =============================================================================
# ANTHROPIC API KEY (obbligatoria)
# =============================================================================
# Usata per: descrizione frame con Claude Vision + analisi processo + raffinamento trascrizione
# Ottieni la tua key su: https://console.anthropic.com/ → API Keys → Create Key
# Formato: sk-ant-...
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =============================================================================
# WHISPER BACKEND (opzionale — serve solo con --audio o --audio-only)
# =============================================================================
# Seleziona quale sistema usare per trascrivere l'audio del video.
#
# Opzioni disponibili:
#
#   faster-whisper  → locale, veloce, leggero (NON richiede PyTorch)
#                     Installa con: pip install faster-whisper
#                     Consigliato per chi ha RAM limitata o vuole rapidità
#
#   openai-whisper  → locale, implementazione ufficiale OpenAI (richiede PyTorch ~2 GB)
#                     Installa con: pip install openai-whisper
#                     Consigliato se vuoi il modello di riferimento ufficiale
#
#   openai-api      → cloud, nessuna installazione locale pesante
#                     Installa con: pip install openai
#                     Richiede OPENAI_API_KEY compilata qui sotto
#                     Costo: ~$0.006/minuto di audio
#                     Limite: file audio max 25 MB (~3-4 ore di parlato)
#
# Default se non specificato: faster-whisper
WHISPER_BACKEND=faster-whisper


# =============================================================================
# WHISPER MODEL (opzionale)
# =============================================================================
# Dimensione del modello da usare per i backend locali (faster-whisper, openai-whisper).
# Più grande = più accurato ma più lento e più RAM richiesta.
#
# Modelli disponibili per backend locali:
#   tiny    →  ~39 MB download |  ~1 GB RAM | molto veloce | qualità base
#   base    →  ~74 MB download |  ~1 GB RAM | veloce       | buona qualità
#   small   → ~244 MB download |  ~2 GB RAM | medio        | qualità migliore
#   medium  → ~769 MB download |  ~5 GB RAM | lento        | alta qualità
#   large-v3 → ~1.5 GB download | ~10 GB RAM | molto lento  | massima qualità
#
# Se usi WHISPER_BACKEND=openai-api, l'unico valore valido è:
#   whisper-1  → modello cloud OpenAI (dimensione irrilevante, gira sui loro server)
#
# Può essere sovrascritto a runtime con: --whisper-model <nome>
# Esempio: python analyze_video.py --audio --whisper-model medium
#
# Default se non specificato: large-v3 (backend locali) oppure whisper-1 (openai-api)
WHISPER_MODEL=large-v3


# =============================================================================
# OPENAI API KEY (opzionale — serve solo se WHISPER_BACKEND=openai-api)
# =============================================================================
# Necessaria SOLO se hai scelto WHISPER_BACKEND=openai-api qui sopra.
# Se usi faster-whisper o openai-whisper, lascia questo campo vuoto.
#
# Ottieni la tua key su: https://platform.openai.com/api-keys → Create new secret key
# Formato: sk-...
OPENAI_API_KEY=
